{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "opensidian",
	"compatibility_date": "2025-11-04",
	// --- Custom domains: opensidian.com + opensidian.epicenter.so (auto-creates DNS records on deploy) ---
	"routes": [
		{
			"pattern": "opensidian.com",
			"custom_domain": true
		},
		{
			"pattern": "opensidian.epicenter.so",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "build",
		"not_found_handling": "single-page-application"
	},
	// Enable preview URLs for PR previews via `wrangler versions upload --preview-alias`
	"preview_urls": true,
	"observability": {
		"enabled": true
	}
}
